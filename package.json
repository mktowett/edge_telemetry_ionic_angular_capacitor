{
  "name": "edge-rum-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Real User Monitoring SDK for Ionic Angular Capacitor apps",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "pnpm -r --filter './packages/*' run build",
    "clean": "pnpm -r --filter './packages/*' run clean && rm -rf node_modules/.cache",
    "lint": "eslint \"packages/*/src/**/*.ts\" \"test/**/*.ts\"",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "playwright test",
    "size": "size-limit",
    "terminology-check": "node scripts/terminology-check.mjs",
    "attribute-flatness-check": "node scripts/attribute-flatness-check.mjs",
    "pack-audit": "node scripts/pack-audit.mjs",
    "changeset": "changeset",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.9",
    "@size-limit/preset-small-lib": "^11.1.6",
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "size-limit": "^11.1.6",
    "tsup": "^8.3.0",
    "typescript": "^5.5.4",
    "vitest": "^2.1.1"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  }
}
