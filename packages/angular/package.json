{
  "name": "@nathanclaire/rum-angular",
  "version": "1.0.0",
  "description": "Angular integration for edge-rum",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md"],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@nathanclaire/rum": "workspace:*"
  },
  "peerDependencies": {
    "@angular/common": ">=16.0.0",
    "@angular/core": ">=16.0.0",
    "@angular/router": ">=16.0.0",
    "rxjs": ">=7.0.0"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.5.4"
  }
}
