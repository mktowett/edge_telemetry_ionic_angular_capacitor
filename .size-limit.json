[
  {
    "name": "@edgemetrics/rum (core)",
    "path": "packages/core/dist/index.mjs",
    "limit": "90 KB",
    "gzip": true
  },
  {
    "name": "@edgemetrics/rum-angular",
    "path": "packages/angular/dist/index.mjs",
    "limit": "60 KB",
    "gzip": true,
    "ignore": [
      "@angular/core",
      "@angular/common",
      "@angular/router",
      "rxjs",
      "rxjs/operators"
    ]
  },
  {
    "name": "@edgemetrics/rum-capacitor",
    "path": "packages/capacitor/dist/index.mjs",
    "limit": "60 KB",
    "gzip": true,
    "ignore": [
      "@capacitor/core",
      "@capacitor/device",
      "@capacitor/network",
      "@capacitor/app"
    ]
  },
  {
    "name": "full stack (core + angular + capacitor)",
    "path": [
      "packages/core/dist/index.mjs",
      "packages/angular/dist/index.mjs",
      "packages/capacitor/dist/index.mjs"
    ],
    "limit": "200 KB",
    "gzip": true,
    "ignore": [
      "@angular/core",
      "@angular/common",
      "@angular/router",
      "rxjs",
      "rxjs/operators",
      "@capacitor/core",
      "@capacitor/device",
      "@capacitor/network",
      "@capacitor/app"
    ]
  }
]
