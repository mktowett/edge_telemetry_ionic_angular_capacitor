{
  "name": "@edgemetrics/rum",
  "version": "0.0.1",
  "description": "Real User Monitoring SDK core for Ionic Angular Capacitor apps",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "THIRD_PARTY_LICENSES"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.5.4"
  },
  "dependencies": {
    "web-vitals": "^4.2.4"
  }
}
