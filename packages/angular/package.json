{
  "name": "@nathanclaire/rum-angular",
  "version": "1.0.3",
  "description": "Angular integration for edge-rum",
  "license": "MIT",
  "type": "module",
  "main": "./dist/fesm2022/nathanclaire-rum-angular.mjs",
  "module": "./dist/fesm2022/nathanclaire-rum-angular.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "ng-packagr -p ng-package.json -c tsconfig.lib.json",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@nathanclaire/rum": "workspace:*"
  },
  "peerDependencies": {
    "@angular/common": ">=16.0.0",
    "@angular/core": ">=16.0.0",
    "@angular/router": ">=16.0.0",
    "rxjs": ">=7.0.0"
  },
  "devDependencies": {
    "@angular/compiler": "^18.0.0",
    "@angular/compiler-cli": "^18.0.0",
    "@angular/common": "^18.0.0",
    "@angular/core": "^18.0.0",
    "@angular/router": "^18.0.0",
    "ng-packagr": "^18.0.0",
    "rxjs": "^7.8.0",
    "typescript": "~5.5.4",
    "zone.js": "~0.14.0"
  }
}
